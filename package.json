{
  "name": "omninav",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:ext-zip": "./scripts/build-extension-zip.sh",
    "preview": "vite preview",
    "dev:api": "vite build && wrangler pages dev dist --port 8789 --kv=KV_OMNINAV",
    "dev:all": "vite build && concurrently -n fe,api \"vite\" \"wrangler pages dev dist --port 8789 --kv=KV_OMNINAV\"",
    "deploy": "npm run build:ext-zip && vite build && wrangler pages deploy dist --project-name=omninav",
    "reset:prod": "./scripts/reset-production-kv.sh",
    "version:minor": "./scripts/bump-version.sh minor",
    "version:major": "./scripts/bump-version.sh major",
    "version:web-patch": "./scripts/bump-version.sh web-patch",
    "version:ext-patch": "./scripts/bump-version.sh ext-patch"
  },
  "dependencies": {
    "@vueuse/core": "^10.7.0",
    "dompurify": "^3.3.2",
    "hono": "^4.0.0",
    "marked": "^17.0.4",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.2.5",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^9.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.4.0",
    "vite": "^5.0.0",
    "vue-tsc": "^2.0.0",
    "wrangler": "^3.0.0"
  },
  "overrides": {
    "esbuild": "^0.24.0"
  }
}
