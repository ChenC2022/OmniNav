{
  "name": "omninav",
  "private": true,
  "version": "0.2.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "dev:api": "vite build && wrangler pages dev dist --port 8789 --kv=KV_OMNINAV",
    "dev:all": "vite build && concurrently -n fe,api \"vite\" \"wrangler pages dev dist --port 8789 --kv=KV_OMNINAV\"",
    "deploy": "vite build && wrangler pages deploy dist --project-name=omninav"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.2.5",
    "pinia": "^2.1.7",
    "@vueuse/core": "^10.7.0",
    "hono": "^4.0.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "~5.4.0",
    "vite": "^5.0.0",
    "vue-tsc": "^2.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "wrangler": "^3.0.0",
    "concurrently": "^9.0.0"
  },
  "overrides": {
    "esbuild": "^0.24.0"
  }
}