{
  "manifest_version": 3,
  "name": "OmniNav",
  "description": "OmniNav 浏览器插件：检索、置顶、快捷添加、AI 会话",
  "version": "1.0.2",
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "OmniNav",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "options_page": "options.html",
  "side_panel": {
    "default_path": "ai.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["storage", "tabs", "contextMenus", "commands", "notifications", "sidePanel"],
  "optional_host_permissions": ["*://*/*"],
  "commands": {
    "open-popup": {
      "suggested_key": { "default": "Ctrl+Shift+K", "mac": "Command+Shift+K" },
      "description": "打开 OmniNav"
    }
  }
}

